# Copia este archivo a .env y completa los valores

FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# MySQL local (crea la base: CREATE DATABASE fe_reflexiones CHARACTER SET utf8mb4;)
DATABASE_URL=mysql+pymysql://usuario:contraseña@127.0.0.1:3306/fe_reflexiones?charset=utf8mb4

# Railway: opción A — en el servicio WEB añade variables referenciadas desde el plugin MySQL:
#   MYSQL_URL, MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE
#   (el código convierte mysql:// a mysql+pymysql:// y arma la URI si faltara).
# Opción B — una sola variable (nombre de base en Railway suele ser "railway"):
# DATABASE_URL=mysql+pymysql://root:TU_PASSWORD@mysql.railway.internal:3306/railway?charset=utf8mb4

# Correo (Gmail: usar contraseña de aplicación https://support.google.com/accounts/answer/185833)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_contraseña_de_aplicacion
MAIL_DEFAULT_SENDER="Fe y Reflexión <tu_correo@gmail.com>"

# URL base para enlaces en correos (sin barra final)
APP_BASE_URL=http://127.0.0.1:5000

# Groq API key https://console.groq.com/keys
GROQ_API_KEY=

# Correo del desarrollador (soporte)
DEVELOPER_EMAIL=andres.herreraote@gmail.com
